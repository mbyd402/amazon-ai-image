# Vercel 生产环境变量示例
# 在 Vercel Dashboard → Settings → Environment Variables 中配置这些变量

# Supabase 配置（必需）
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# API 密钥（可选，可设置为空字符串）
REMOVE_BG_API_KEY=""
CLOUDMERSIVE_API_KEY=""
CLIPDROP_API_KEY=""
NEXT_PUBLIC_PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
SUPABASE_SERVICE_ROLE_KEY=""

# 注意：
# 1. NEXT_PUBLIC_ 前缀的变量会在构建时内联到客户端代码
# 2. 其他变量只在服务器端可用
# 3. 在 Vercel 中配置后，需要重新部署才能生效