{"type":"app","meta":{"headers":{"x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/"}},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/css/f8bc7b451f599f89.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-03f7c6bc932ce1e3.js\"/><script src=\"/_next/static/chunks/fd9d1056-42a1c2df9c4a85a8.js\" async=\"\"></script><script src=\"/_next/static/chunks/117-d6db125f63886513.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-4fa3203e6612cf2d.js\" async=\"\"></script><script src=\"/_next/static/chunks/972-d572eae3505c0e7f.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/page-39d9b996894780cb.js\" async=\"\"></script><script src=\"/_next/static/chunks/44530001-5f86e157ede9686f.js\" async=\"\"></script><script src=\"/_next/static/chunks/303-b73a131c003791f2.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-c4b41f7f364a3c3d.js\" async=\"\"></script><title>Amazon Image Pro - Background, Watermark Remover, Upscale &amp; Compliance Check</title><meta name=\"description\" content=\"One-stop image tools for Amazon sellers. Create pure white background, remove watermark/text/logo, upscale image, check compliance.\"/><script>(self.__next_s=self.__next_s||[]).push([0,{\"children\":\"\\n            // 阻止常见的钱包注入\\n            const blockWallets = () => {\\n              // MetaMask\\n              if (typeof window.ethereum !== 'undefined') {\\n                console.warn('Wallet extension detected. This may interfere with normal operation.');\\n              }\\n              \\n              // 阻止window.ethereum的某些方法\\n              Object.defineProperty(window, 'ethereum', {\\n                get() {\\n                  console.log('Blocked access to ethereum object');\\n                  return null;\\n          