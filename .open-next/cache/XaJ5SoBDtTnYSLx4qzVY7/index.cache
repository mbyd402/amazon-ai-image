-6 text-blue-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 16l4.584-4.585a2 2 0 012.83 0L16 16m-2-2l1.584-1.585a2 2 0 012.83 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z\"></path></svg></div><h3 class=\"text-lg font-semibold text-gray-900 dark:text-white\">Background Changer</h3><p class=\"mt-2 text-gray-500 dark:text-gray-300\">Automatically remove background and set pure white (RGB 255,255,255) that meets Amazon&#x27;s requirements.</p></div><div class=\"p-6 bg-white rounded-lg shadow-lg dark:bg-gray-800\"><div class=\"w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mb-4\"><svg class=\"w-6 h-6 text-blue-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16\"></path></svg></div><h3 class=\"text-lg font-semibold text-gray-900 dark:text-white\">Remove Watermark</h3><p class=\"mt-2 text-gray-500 dark:text-gray-300\">AI-powered watermark, text, and logo removal from supplier images. Perfect for 1688/Alibaba sourcing.</p></div><div class=\"p-6 bg-white rounded-lg shadow-lg dark:bg-gray-800\"><div class=\"w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mb-4\"><svg class=\"w-6 h-6 text-blue-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M4 16l1.4-1.4A4 4 0 017.8 14H16a2 2 0 012 2v1.5m.25-6.858l2.408-2.408c.78-.78.217-2.108-.879-2.108H18.5m-7 11h.01\"></path></svg></div><h3 class=\"text-lg font-semibold text-gray-900 dark:text-white\">Upscale &amp; Enhance</h3><p class=\"mt-2 text-gray-500 dark:text-gray-300\">Upscale images up to 4x while enhancing quality. Meet Amazon&#x27;s 1000px minimum requirement for zoom.</p></div><div class=\"p-6 bg-white rounded-lg shadow-lg dark:bg-gray-800\"><div class=\"w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mb-4\"><svg class=\"w-6 h-6 text-blue-600\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z\"></path></svg></div><h3 class=\"text-lg font-semibold text-gray-900 dark:text-white\">Compliance Check</h3><p class=\"mt-2 text-gray-500 dark:text-gray-300\">Check if your main image meets Amazon&#x27;s policies. Avoid rejection and get your listings live faster.</p></div></div></div><div class=\"bg-gray-50 dark:bg-gray-900\"><div class=\"max-w-7xl mx-auto px-4 py-16 sm:px-6 lg:px-8\"><div class=\"text-center\"><h2 class=\"text-3xl font-extrabold text-gray-900 dark:text-white\">Simple, Transparent Pricing</h2><p class=\"mt-4 text-xl text-gray-500 dark:text-gray-300\">Pay as you go, no subscriptions required. Points never expire.</p></div><div class=\"mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4\"><div class=\"bg-white dark:bg-gray-800 p-6 rounded-lg shadow-lg border-2 border-gray-200 dark:border-gray-700\"><h3 class=\"text-lg font-semibold text-gray-900 dark:text-white\">Free Trial</h3><div class=\"mt-4\"><span class=\"text-4xl font-bold text-gray-900 dark:text-white\">$0</span></div><ul class=\"mt-6 space-y-4\"><li class=\"flex items-center\"><svg class=\"w-5 h-5 text-green-500\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"></path></svg><span class=\"ml-2 text-gray-500 dark:text-gray-300\">3 images free</span></li><li class=\"flex items-center\"><svg class=\"w-5 h-5 text-green-500\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1