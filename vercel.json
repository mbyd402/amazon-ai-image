{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NODE_VERSION": "18.20.4"
  },
  "build": {
    "env": {
      "NEXT_PUBLIC_SUPABASE_URL": "",
      "NEXT_PUBLIC_SUPABASE_ANON_KEY": "",
      "REMOVE_BG_API_KEY": "",
      "CLOUDMERSIVE_API_KEY": "",
      "CLIPDROP_API_KEY": "",
      "NEXT_PUBLIC_PAYPAL_CLIENT_ID": "",
      "PAYPAL_CLIENT_SECRET": "",
      "SUPABASE_SERVICE_ROLE_KEY": ""
    }
  }
}